# Скопируйте этот файл в .env и поменяйте значения перед запуском в продакшене.

# Секрет для подписи JWT. ОБЯЗАТЕЛЬНО смените на длинную случайную строку в продакшене.
JWT_SECRET=change-this-secret-in-production

# Порт, на котором будет доступен фронтенд снаружи (http://localhost:PORT)
FRONTEND_PORT=8080

# Origin фронтенда — используется backend для настройки CORS
FRONTEND_ORIGIN=http://localhost:8080

# OAuth
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Приватный ключ Apple Sign In (.p8). Docker Compose читает .env построчно, поэтому
# многострочный PEM-ключ нужно записать в кавычках с literal \n вместо переводов строк, например:
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGHAgEA...\n-----END PRIVATE KEY-----"
APPLE_PRIVATE_KEY=

# SMTP (invite emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
