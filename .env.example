# Скопируйте этот файл в .env и поменяйте значения перед запуском в продакшене.

# Секрет для подписи JWT. ОБЯЗАТЕЛЬНО смените на длинную случайную строку в продакшене.
JWT_SECRET=change-this-secret-in-production

# Порт, на котором будет доступен фронтенд снаружи (http://localhost:PORT)
FRONTEND_PORT=8080

# Origin фронтенда — используется backend для настройки CORS
FRONTEND_ORIGIN=http://localhost:8080
